{
  "__inputs": [],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": { "list": [] },
  "description": "Cross-service incident investigation — identify root cause from timeline correlation",
  "editable": false,
  "graphTooltip": 2,
  "id": null,
  "links": [
    {
      "icon": "arrow-left",
      "title": "Back to System Overview",
      "type": "link",
      "url": "/d/system-overview"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 300,
      "title": "Cross-Service Error Rates — Who Failed First?",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(255,0,0,0.1)", "value": 10 }
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "auth-service" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "payment-service" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "order-service" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 1 },
      "id": 301,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "sum(rate(http_errors_total{service=\"auth-service\"}[2m])) / sum(rate(http_requests_total{service=\"auth-service\"}[2m])) * 100",
          "legendFormat": "auth-service",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "sum(rate(http_errors_total{service=\"payment-service\"}[2m])) / sum(rate(http_requests_total{service=\"payment-service\"}[2m])) * 100",
          "legendFormat": "payment-service",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "sum(rate(http_errors_total{service=\"order-service\"}[2m])) / sum(rate(http_requests_total{service=\"order-service\"}[2m])) * 100",
          "legendFormat": "order-service",
          "refId": "C"
        }
      ],
      "title": "All Services Error Rate on Same Timeline — The line that spikes FIRST is the root cause",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 310,
      "title": "Cross-Service P99 Latency — Which service degraded first?",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "thresholdsStyle": { "mode": "line" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          },
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "auth-service P99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "payment-service P99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "order-service P99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 11 },
      "id": 311,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"auth-service\"}[5m])) by (le)) * 1000",
          "legendFormat": "auth-service P99",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"payment-service\"}[5m])) by (le)) * 1000",
          "legendFormat": "payment-service P99",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"order-service\"}[5m])) by (le)) * 1000",
          "legendFormat": "order-service P99",
          "refId": "C"
        }
      ],
      "title": "All Services P99 Latency — Correlate spikes to find cascade origin",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 320,
      "title": "Service Uptime & Availability",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 80,
            "lineInterpolation": "stepAfter",
            "lineWidth": 0,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 21 },
      "id": 321,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "up{job=\"auth-service\"}",
          "legendFormat": "auth-service",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "up{job=\"payment-service\"}",
          "legendFormat": "payment-service",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "up{job=\"order-service\"}",
          "legendFormat": "order-service",
          "refId": "C"
        }
      ],
      "title": "Service Uptime Timeline — Green=UP Red=DOWN",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 330,
      "title": "Failure Simulation Indicators",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 331,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "sum(rate(downstream_calls_total{status=\"timeout\"}[1m])) by (service, target)",
          "legendFormat": "{{service}} → {{target}} timeouts",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "sum(rate(downstream_calls_total{status=\"unreachable\"}[1m])) by (service, target)",
          "legendFormat": "{{service}} → {{target}} unreachable",
          "refId": "B"
        }
      ],
      "title": "Timeout & Unreachable Events — Direct failure simulation evidence",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 332,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "sum(active_requests) by (service)",
          "legendFormat": "{{service}} active",
          "refId": "A"
        }
      ],
      "title": "Active In-Flight Requests — Spike = requests piling up",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 340,
      "title": "Impact Summary — Current State",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 37 },
      "id": 341,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "sum(rate(http_errors_total[5m])) by (service) / sum(rate(http_requests_total[5m])) by (service) * 100",
          "instant": true,
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Current Error Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 2000 }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 37 },
      "id": 342,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service)) * 1000",
          "instant": true,
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Current P99 Latency",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 37 },
      "id": 343,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "up{job=~\"auth-service|payment-service|order-service\"}",
          "instant": true,
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Service Status",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["incident", "timeline", "sre", "troubleshooting"],
  "templating": { "list": [] },
  "time": { "from": "now-2h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Incident Timeline",
  "uid": "incident-timeline",
  "version": 1
}
